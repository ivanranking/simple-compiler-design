// Conditional Statements
// Demonstrates if-else logic

var score = 85;

print("Grade Calculator");
print("================");
print("Score: ", score);

if (score >= 90) {
    print("Grade: A - Excellent!");
} else if (score >= 80) {
    print("Grade: B - Good!");
} else if (score >= 70) {
    print("Grade: C - Satisfactory");
} else if (score >= 60) {
    print("Grade: D - Passing");
} else {
    print("Grade: F - Failed");
}
