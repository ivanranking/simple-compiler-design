// Nested Loops with Conditions
// Demonstrates complex control flow

print("Multiplication Table");
print("====================");

for (var i = 1; i <= 5; i = i + 1) {
    for (var j = 1; j <= 5; j = j + 1) {
        var product = i * j;
        print(i, " x ", j, " = ", product);
    }
    print("---");
}
